<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.historyController">
   <children>
      <Label layoutX="367.0" prefHeight="51.0" prefWidth="185.0" text="HISTORY">
         <font>
            <Font name="Comic Sans MS" size="36.0" />
         </font>
      </Label>
      <TableView fx:id="historyTable" layoutY="51.0" prefHeight="528.0" prefWidth="915.0">
        <columns>
          <TableColumn fx:id="elect_no_col" prefWidth="87.99999856948853" text="Election No" />
          <TableColumn fx:id="elect_type_col" prefWidth="269.6000442504883" text="Election Type" />
            <TableColumn fx:id="elect_id_col" prefWidth="336.8000183105469" text="Election Id" />
            <TableColumn fx:id="elect_date_col" prefWidth="219.2000732421875" text="Date of Election" />
        </columns>
      </TableView>
      <Button fx:id="viewButton" layoutX="95.0" layoutY="612.0" mnemonicParsing="false" onAction="#viewSelected" prefHeight="26.0" prefWidth="110.0" styleClass="yes" text="View Result" textFill="#150101" />
      <Button fx:id="backButton" layoutX="559.0" layoutY="613.0" mnemonicParsing="false" onAction="#goBack" prefHeight="26.0" prefWidth="118.0" styleClass="back" text="Back" textFill="RED" />
      <Button fx:id="exitButton" layoutX="785.0" layoutY="613.0" mnemonicParsing="false" onAction="#onExit" prefHeight="26.0" prefWidth="87.0" styleClass="back" text="Exit" textFill="#ff00f2" />
      <Button fx:id="deleteButton" layoutX="301.0" layoutY="613.0" mnemonicParsing="false" onAction="#deleteSelected" prefHeight="26.0" prefWidth="131.0" styleClass="no" text="Delete from History" />
   </children>
</AnchorPane>
