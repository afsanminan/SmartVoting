<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ProgressIndicator?>
<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.showStudentCandidatesController">
   <children>
      <TextField fx:id="searchField" prefHeight="26.0" prefWidth="297.0" promptText="Search Student  Candidate" />
      <Label layoutX="298.0" prefHeight="26.0" prefWidth="334.0" text="Student's Information">
         <font>
            <Font name="Algerian" size="24.0" />
         </font>
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <ComboBox fx:id="deptFilter" layoutX="632.0" prefHeight="26.0" prefWidth="280.0" promptText="Filter Student Canidates by Department" styleClass="forWhite" />
      <TableView fx:id="studentCand_table" layoutY="26.0" prefHeight="593.0" prefWidth="915.0">
        <columns>
          <TableColumn fx:id="candNo_col" prefWidth="60.8000168800354" text="Cand. No"  />
          <TableColumn fx:id="name_col" prefWidth="270.40006256103516" text="Name" style="-fx-text-fill: #fff"/>
            <TableColumn fx:id="stdId_col" prefWidth="141.60003662109375" text="Student Id" />
            <TableColumn fx:id="candId_col" prefWidth="116.80001831054688" text="Canidate Id" />
            <TableColumn fx:id="symbol_col" prefWidth="120.0001220703125" text="Symbol" />
            <TableColumn fx:id="post_col" prefWidth="159.199951171875" text="Post running for" />
            <TableColumn fx:id="dept_col" prefWidth="270.0" text="Department" />
        </columns>
      </TableView>
       <ProgressIndicator fx:id="deleteProgress" layoutX="430.0" layoutY="300.0" visible="false" />
      <Button layoutX="81.0" layoutY="641.0" mnemonicParsing="false" onAction="#addCandidate" prefHeight="26.0" prefWidth="103.0" styleClass="yes" text="Add Candidate" />
      <Button layoutX="423.0" layoutY="642.0" mnemonicParsing="false" onAction="#deleteCandidate" prefHeight="26.0" prefWidth="114.0" styleClass="no" text="Delete Candidate" />
      <Button fx:id="backBtn" layoutX="768.0" layoutY="643.0" mnemonicParsing="false" onAction="#onBack" prefHeight="26.0" prefWidth="75.0" styleClass="back" text="Back" />
   </children>
</AnchorPane>
