<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.historyNationalController">
   <children>
      <Label fx:id="histLabel" layoutX="364.0" prefHeight="51.0" prefWidth="550.0" text="HISTORY">
         <font>
            <Font name="Comic Sans MS" size="36.0" />
         </font>
      </Label>
      <TableView fx:id="nationalTable" layoutY="51.0" prefHeight="528.0" prefWidth="915.0">
        <columns>
          <TableColumn fx:id="const_no_col" prefWidth="75.0" text="Const. No" />
          <TableColumn fx:id="const_name_col" prefWidth="141.59998321533203" text="Constituency" />
            <TableColumn fx:id="winner_name_col" prefWidth="336.8000183105469" text="Winner's Name" />
            <TableColumn fx:id="winner_symbol_col" prefWidth="157.59991455078125" text="Winner's Symbol" />
            <TableColumn fx:id="percentage_col" maxWidth="143.199951171875" prefWidth="100.0" text="Percentage" />
            <TableColumn fx:id="total_voter_col" maxWidth="150.0" prefWidth="150.0" text="Total Voters" />
            <TableColumn fx:id="total_cand_col" prefWidth="140.0" text="Total Candidate" />
        </columns>
      </TableView>
      <Button fx:id="backBtn" layoutX="115.0" layoutY="614.0" mnemonicParsing="false" onAction="#onBack" prefHeight="26.0" prefWidth="68.0" styleClass="back" text="Back" />
      <Button fx:id="exitBtn" layoutX="744.0" layoutY="615.0" mnemonicParsing="false" onAction="#exitApp" prefHeight="26.0" prefWidth="74.0" styleClass="no" text="Exit" />
   </children>
</AnchorPane>
