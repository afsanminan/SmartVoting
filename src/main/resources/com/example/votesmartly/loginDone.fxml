<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="683.0"
            prefWidth="915.0" styleClass="options" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.LogInDoneController">
   <children>
      <Label layoutX="241.0" layoutY="133.0" prefHeight="82.0" prefWidth="493.0" text="Welcome Back!!!">
         <font>
            <Font name="Bodoni MT Bold" size="67.0" />
         </font>
      </Label>
      <Button layoutX="283.0" layoutY="242.0" mnemonicParsing="false" onAction="#newElection" prefHeight="54.0"
              prefWidth="382.0" styleClass="buttons" stylesheets="@opening.css" text="➤ Start New Election">
         <font>
            <Font name="Arial Rounded MT Bold" size="23.0" />
         </font>
      </Button>
      <Button layoutX="283.0" layoutY="306.0" mnemonicParsing="false" onAction="#prevElection" prefHeight="54.0"
              prefWidth="381.0" styleClass="buttons" stylesheets="@opening.css" text="➤ Continue Previous Election">
         <font>
            <Font name="Arial Rounded MT Bold" size="23.0" />
         </font>
      </Button>
      <Button layoutX="282.0" layoutY="372.0" mnemonicParsing="false" onAction="#onHistory" prefHeight="54.0"
              prefWidth="382.0" styleClass="buttons" stylesheets="@opening.css" text="➤ History">
         <font>
            <Font name="Arial Rounded MT Bold" size="23.0" />
         </font>
      </Button>
      <Button layoutX="282.0" layoutY="439.0" mnemonicParsing="false" onAction="#onExit" prefHeight="54.0"
              prefWidth="382.0" styleClass="buttons" stylesheets="@opening.css" text="➤ Exit">
         <font>
            <Font name="Arial Rounded MT Bold" size="23.0" />
         </font>
      </Button>
      <AnchorPane fx:id="popupPane"  layoutX="304.0" layoutY="269.0" prefHeight="174.0" prefWidth="338.0" styleClass="forWhite"
                  stylesheets="@opening.css" visible="false">
         <children>
            <Label layoutX="84.0" layoutY="14.0" prefHeight="62.0" prefWidth="215.0" text="Are you sure???" wrapText="true">
               <font>
                  <Font name="Agency FB Bold" size="29.0" />
               </font>
            </Label>
            <Label layoutX="49.0" layoutY="67.0" prefHeight="18.0" prefWidth="240.0"
                   text="Data from previous election will be deleted!!" />
            <Button fx:id="yesBtn" layoutX="58.0" layoutY="120.0" mnemonicParsing="false" prefHeight="18.0"
                    prefWidth="88.0" styleClass="yes" stylesheets="@opening.css" text="YES" />
            <Button fx:id="noBtn" layoutX="192.0" layoutY="120.0" mnemonicParsing="false" prefHeight="26.0"
                    prefWidth="82.0" styleClass="no" stylesheets="@opening.css" text="CANCEL" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
