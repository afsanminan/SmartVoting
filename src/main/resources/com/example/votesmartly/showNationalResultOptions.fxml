<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="683.0" prefWidth="915.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.showNationalResultOptionsController">
   <children>
      <ImageView fitHeight="220.0" fitWidth="267.0" layoutX="327.0" layoutY="75.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../../../../../voteDone.jpg" />
         </image>
      </ImageView>
      <Label layoutX="230.0" layoutY="293.0" prefHeight="50.0" prefWidth="491.0" text="Congratulations!!! Election is finished successfuly!" textFill="#00c8ff">
         <font>
            <Font name="Freestyle Script" size="36.0" />
         </font>
      </Label>
      <Button fx:id="showResult" layoutX="384.0" layoutY="537.0" mnemonicParsing="false" onAction="#onShow" prefHeight="26.0" prefWidth="201.0" styleClass="yes" stylesheets="@opening.css" text="View Overall Result" />
      <Label layoutX="230.0" layoutY="342.0" prefHeight="168.0" prefWidth="491.0" text="This election has been a true success because of the voters who participated with responsibility and commitment. Every vote mattered and helped strengthen the spirit of democracy.The same enthusiasm and awareness should continue in the future. Active participation in upcoming elections will ensure even greater progress and unity.Thank you for making this election meaningful." wrapText="true">
         <font>
            <Font name="Gill Sans Ultra Bold Condensed" size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
