<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.showNationalVoterController">

    <children>
        <TableView fx:id="voter_table" layoutY="29.0" prefHeight="582.0" prefWidth="915.0">
            <columns>
                <TableColumn fx:id="voter_no_col" prefWidth="75.0" text="Voter No" />
                <TableColumn fx:id="name_col" prefWidth="333.6" text="Name"  />
                <TableColumn fx:id="dob_col" prefWidth="127.2" text="Date of Birth" />
                <TableColumn fx:id="voter_id_col" prefWidth="226.4" text="Voter Id" />
                <TableColumn fx:id="const_col" prefWidth="150.4" text="Constituency" />
            </columns>
        </TableView>

        <ProgressIndicator fx:id="deleteProgress" layoutX="430.0" layoutY="300.0" visible="false" />

        <Button layoutX="44.0" layoutY="637.0" onAction="#addVoters" prefHeight="26.0" prefWidth="145.0" styleClass="yes" text="Add Voters" />

        <Button layoutX="406.0" layoutY="637.0" onAction="#removeVoters" prefHeight="26.0" prefWidth="138.0" styleClass="no" text="Delete Voters" />

        <Button fx:id="backBtn" layoutX="756.0" layoutY="638.0" onAction="#onBack" prefHeight="26.0" prefWidth="94.0" styleClass="back" text="Back" />
      <TextField fx:id="searchField" layoutY="1.0" prefHeight="26.0" prefWidth="345.0" promptText="Search Voter" />
      <ComboBox fx:id="constFilter" layoutX="595.0" layoutY="2.0" prefHeight="26.0" prefWidth="320.0" promptText="Filter Voters by Constituency" styleClass="forWhite" />
      <Label layoutX="355.0" prefHeight="26.0" prefWidth="239.0" text="Voters Information">
         <font>
            <Font name="Arial Rounded MT Bold" size="24.0" />
         </font>
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
    </children>
</AnchorPane>
