<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.stdOverallResultController">
   <children>
      <Label fx:id="electionIdLabel" layoutX="307.0" prefHeight="48.0" prefWidth="608.0" text="Result of " textFill="#15a5e5">
         <font>
            <Font name="Brush Script MT Italic" size="36.0" />
         </font>
      </Label>
      <PieChart fx:id="resultChart" layoutX="24.0" layoutY="469.0" prefHeight="203.0" prefWidth="400.0" />
      <Label fx:id="total_voters_label" layoutX="500.0" layoutY="501.0" prefHeight="26.0" prefWidth="259.0" text="Total Voters :" />
      <Label fx:id="total_cand_label" layoutX="497.0" layoutY="536.0" prefHeight="26.0" prefWidth="259.0" text="Total Candidates :" />
      <Label fx:id="vote_casted_label" layoutX="497.0" layoutY="571.0" prefHeight="26.0" prefWidth="259.0" text="Total Vote Casted :" />
      <Label fx:id="percent_Label" layoutX="497.0" layoutY="597.0" prefHeight="26.0" prefWidth="259.0" text="Vote Casting Percentage :" />
      <Button fx:id="postResultButton" layoutX="716.0" layoutY="469.0" mnemonicParsing="false" onAction="#onPostResultButton" prefHeight="26.0" prefWidth="172.0" text="Show Post Result" />
      <Button fx:id="backBtn" layoutX="766.0" layoutY="645.0" mnemonicParsing="false" onAction="#onExit" prefHeight="26.0" prefWidth="101.0" styleClass="back" text="Exit" />
      <TableView fx:id="overallTable" layoutY="48.0" prefHeight="406.0" prefWidth="915.0">
        <columns>
          <TableColumn fx:id="post_no_col" prefWidth="53.600035190582275" text="Post No" />
          <TableColumn fx:id="post_name_col" prefWidth="325.59998321533203" text="Post Name" />
            <TableColumn fx:id="total_cand_col" prefWidth="130.39999389648438" text="Total Canidates" />
            <TableColumn fx:id="winner_col" prefWidth="320.79998779296875" text="Winner" />
            <TableColumn fx:id="winner_symbol_col" prefWidth="150.0" text="Winner's Symbol" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
