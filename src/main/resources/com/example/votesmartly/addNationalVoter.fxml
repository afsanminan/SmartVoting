<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ProgressBar?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.addNationalVoterController">
   <children>
      <Label layoutX="98.0" layoutY="91.0" prefHeight="38.0" prefWidth="273.0" text="Add Voters from a file :">
         <font>
            <Font name="Bodoni MT" size="24.0" />
         </font>
      </Label>
      <Label layoutX="98.0" layoutY="305.0" prefHeight="52.0" prefWidth="220.0" text="Add Voter manually :">
         <font>
            <Font name="Bodoni MT" size="24.0" />
         </font>
      </Label>
      <Label layoutX="207.0" layoutY="358.0" prefHeight="27.0" prefWidth="106.0" text="Name :">
         <font>
            <Font name="Berlin Sans FB" size="18.0" />
         </font>
      </Label>
      <Label layoutX="207.0" layoutY="411.0" prefHeight="27.0" prefWidth="106.0" text="Date of Birth :">
         <font>
            <Font name="Berlin Sans FB" size="18.0" />
         </font>
      </Label>
      <Label layoutX="207.0" layoutY="463.0" prefHeight="27.0" prefWidth="106.0" text="Voter Id :">
         <font>
            <Font name="Berlin Sans FB" size="18.0" />
         </font>
      </Label>
      <Label layoutX="207.0" layoutY="522.0" prefHeight="27.0" prefWidth="106.0" text="Constituency :">
         <font>
            <Font name="Berlin Sans FB" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="nameField" layoutX="326.0" layoutY="360.0" prefHeight="26.0" prefWidth="357.0" promptText="Please Enter Name of Voter" />
      <TextField fx:id="voterIdField" layoutX="324.0" layoutY="464.0" prefHeight="26.0" prefWidth="358.0" promptText="Please Enter Voter Id" />
      <DatePicker fx:id="dobPicker" layoutX="328.0" layoutY="412.0" promptText="Select Date of Birth" />
      <Button layoutX="229.0" layoutY="602.0" mnemonicParsing="false" onAction="#addVoter" prefHeight="26.0" prefWidth="106.0" styleClass="yes" stylesheets="@opening.css" text="Add Voter" />
      <Button layoutX="527.0" layoutY="602.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="106.0" styleClass="no" text="Cancel" />
      <ComboBox fx:id="constituencyBox" layoutX="323.0" layoutY="522.0" prefHeight="26.0" prefWidth="214.0" promptText="Select Constituency" />
      <Label fx:id="duplicateLabel" layoutX="328.0" layoutY="497.0" prefHeight="18.0" prefWidth="220.0" text="A voter with this Id already exists!" visible="false">
         <styleClass>
            <String fx:value="forWhite" />
            <String fx:value="back" />
         </styleClass>
      </Label>
      <Button fx:id="fileButton" layoutX="342.0" layoutY="98.0" mnemonicParsing="false" onAction="#chooseFile" prefHeight="26.0" prefWidth="214.0" styleClass="root-bg" text="Please Select Necessary files" />
      <ListView fx:id="listView" layoutX="337.0" layoutY="129.0" prefHeight="142.0" prefWidth="358.0" styleClass="mark" />
      <Button layoutX="336.0" layoutY="292.0" mnemonicParsing="false" onAction="#addVotersFromFile" prefHeight="26.0" prefWidth="94.0" styleClass="yes" text="Add Voters " />
      <ProgressBar fx:id="progressBar"
                   layoutX="337.0"
                   layoutY="330.0"
                   prefWidth="358.0"
                   visible="false" />
      <Button layoutX="610.0" layoutY="292.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="94.0" styleClass="no" text="Remove Files" />
      <Label fx:id="fileError" layoutX="337.0" layoutY="271.0" prefHeight="18.0" prefWidth="175.0" text="Invalid Files!" visible="false">
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <Label fx:id="dobError" layoutX="325.0" layoutY="441.0" prefHeight="18.0" prefWidth="358.0" text="Date of Birth shows ineligibility!" visible="false">
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <Label fx:id="nameError" layoutX="325.0" layoutY="386.0" prefHeight="18.0" prefWidth="358.0" text="Name can not be empty!" visible="false">
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <Label fx:id="constError" layoutX="323.0" layoutY="549.0" prefHeight="18.0" prefWidth="358.0" text="A constituency must be selected!" visible="false">


         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <Button layoutX="719.0" layoutY="642.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="86.0"
              styleClass="back" text="Back" onAction="#onBack"/>

   </children>
</AnchorPane>
