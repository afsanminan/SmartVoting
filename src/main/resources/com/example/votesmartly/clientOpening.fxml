            <Font name="Franklin Gothic Heavy" size="36.0" />
         </font>
      </Button>
      <Button layoutX="720.0" layoutY="600.0" mnemonicParsing="false" onAction="#onExit" prefHeight="26.0" prefWidth="99.0" styleClass="back" text="Exit" />
      <ImageView fitHeight="205.0" fitWidth="366.0" layoutX="388.0" layoutY="50.0" pickOnBounds="true" preserveRatio="true">
