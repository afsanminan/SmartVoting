<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ProgressIndicator?>
<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.showStudentVotersController">
   <children>
      <TextField fx:id="searchField" prefHeight="26.0" prefWidth="297.0" promptText="Search Student" />
      <Label layoutX="298.0" prefHeight="26.0" prefWidth="334.0" text="Student's Information">
         <font>
            <Font name="Algerian" size="24.0" />
         </font>
         <styleClass>
            <String fx:value="back" />
            <String fx:value="forWhite" />
         </styleClass>
      </Label>
      <ComboBox fx:id="deptFilter" layoutX="633.0" prefHeight="26.0" prefWidth="280.0" promptText="Filter Students by Department" styleClass="forWhite" />
      <TableView fx:id="student_table" layoutY="26.0" prefHeight="583.0" prefWidth="915.0">
        <columns>
          <TableColumn fx:id="stdNo_col" prefWidth="48.8000168800354" text="Std No" />
          <TableColumn fx:id="name_col" prefWidth="387.9999771118164" text="Name" style="-fx-text-fill: #fff" />
            <TableColumn fx:id="stdId_col" prefWidth="139.19992065429688" text="Student Id" />
            <TableColumn fx:id="dept_col" prefWidth="333.60003662109375" text="Department" />
        </columns>
      </TableView>
       <ProgressIndicator fx:id="deleteProgress" layoutX="430.0" layoutY="300.0" visible="false" />
      <Button layoutX="71.0" layoutY="631.0" mnemonicParsing="false" onAction="#addStudent" prefHeight="26.0" prefWidth="103.0" styleClass="yes" text="Add Student" />
      <Button layoutX="413.0" layoutY="632.0" mnemonicParsing="false" onAction="#deleteStudent" prefHeight="26.0" prefWidth="114.0" styleClass="no" text="Delete Student" />
      <Button fx:id="backBtn" layoutX="758.0" layoutY="633.0" mnemonicParsing="false" onAction="#onBack" prefHeight="26.0" prefWidth="75.0" styleClass="back" text="Back" />
   </children>
</AnchorPane>
