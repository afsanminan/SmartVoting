<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="683.0" prefWidth="915.0" stylesheets="@opening.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.votesmartly.historyStdController">
   <children>
      <Label fx:id="histLabel" layoutX="374.0" prefHeight="51.0" prefWidth="548.0" text="HISTORY">
         <font>
            <Font name="Comic Sans MS" size="36.0" />
         </font>
      </Label>
      <TableView fx:id="stdTable" layoutY="51.0" prefHeight="528.0" prefWidth="923.0">
         <columns>
            <TableColumn fx:id="post_no_col" prefWidth="75.0" text="Post No" />
            <TableColumn fx:id="post_name_col" prefWidth="251.19998931884766" text="Post Name" />
            <TableColumn fx:id="winner_name_col" prefWidth="228.80001831054688" text="Winner's Name" />
            <TableColumn fx:id="winner_symbol_col" prefWidth="157.59991455078125" text="Winner's Symbol" />
            <TableColumn fx:id="total_voter_col" maxWidth="150.0" prefWidth="150.0" text="Total Voters" />
            <TableColumn fx:id="total_cand_col" prefWidth="140.0" text="Total Candidate" />
         </columns>
      </TableView>
      <Button fx:id="backBtn" layoutX="125.0" layoutY="624.0" mnemonicParsing="false" onAction="#onBack" prefHeight="26.0" prefWidth="68.0" styleClass="back" text="Back" />
      <Button fx:id="exitBtn" layoutX="754.0" layoutY="625.0" mnemonicParsing="false" onAction="#onExit" prefHeight="26.0" prefWidth="74.0" styleClass="no" text="Exit" />
   </children>
</AnchorPane>
